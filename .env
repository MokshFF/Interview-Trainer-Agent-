FLASK_SECRET_KEY=change-me
FLASK_DEBUG=false
PORT=5000
MAX_UPLOAD_MB=10
ORCHESTRATE_APIKEY=your_orchestrate_api_key
ORCHESTRATE_IAM_APIKEY=your_orchestrate_iam_api_key
ORCHESTRATE_URL=https://api.your-region.watson-orchestrate.cloud.ibm.com/instances/your-instance-id
ORCHESTRATE_AUTH_TYPE=iam
ORCHESTRATE_AGENT_ID=your_agent_id
ORCHESTRATE_INVOKE_PATH=api/v1/agents/your_agent_id/chat
ORCHESTRATE_COLLECTION_NAME=interview_knowledge
AGENT_INTERVIEW_STYLE=balanced and professional
AGENT_TONE=supportive, clear, and direct
AGENT_DIFFICULTY=medium
AGENT_COMPANY_FOCUS=adaptable to the target company
AGENT_EVALUATION_CRITERIA=technical accuracy, communication clarity, structure, relevance, and confidence
AGENT_SAFETY_RULES=avoid harmful, private, or discriminatory content; keep guidance job-relevant
AGENT_PERSONALIZATION=use resume details, target role, experience level, skills, and company data to tailor output
